{
  "name": "@vinicioslugli/opencode-background-process",
  "version": "0.2.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "description": "OpenCode plugin for managing background processes - launch, wait for, monitor, and control long-running tasks",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "plugin",
    "background-process",
    "process-manager",
    "dev-server"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ViniciosLugli/opencode-background-process.git"
  },
  "bugs": {
    "url": "https://github.com/ViniciosLugli/opencode-background-process/issues"
  },
  "homepage": "https://github.com/ViniciosLugli/opencode-background-process#readme",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.17.8"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.8",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.19.21",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && bunx tsc && cp -r skills dist/",
    "dev": "opencode plugin dev",
    "typecheck": "bunx tsc --noEmit",
    "prepare": "bun run build",
    "prepublishOnly": "bun run build"
  }
}
